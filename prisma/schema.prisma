generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RoutineActivity {
  id          String               @id @default(cuid())
  dayOfWeek   Int
  title       String
  order       Int                  @default(0)
  completions ActivityCompletion[]
  createdAt   DateTime             @default(now())
}

model ActivityCompletion {
  id         String          @id @default(cuid())
  activityId String
  activity   RoutineActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  date       DateTime        @db.Date
  done       Boolean         @default(false)

  @@unique([activityId, date])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Todo {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Goal {
  id        String       @id @default(cuid())
  title     String
  progress  Int          @default(0)
  note      String       @default("")
  order     Int          @default(0)
  category  GoalCategory @default(PERSONAL)
  createdAt DateTime     @default(now())
}

enum GoalCategory {
  PROFESSIONAL
  PERSONAL
}

model Idea {
  id        String   @id @default(cuid())
  content   String
  tags      String[]
  createdAt DateTime @default(now())
}

model Book {
  id         String     @id @default(cuid())
  title      String
  author     String     @default("")
  status     BookStatus @default(WANT)
  progress   Int        @default(0)
  finishedAt DateTime?
  createdAt  DateTime   @default(now())
}

enum BookStatus {
  READING
  FINISHED
  WANT
}

model Bookmark {
  id        String   @id @default(cuid())
  url       String
  title     String
  tags      String[]
  createdAt DateTime @default(now())
}
